---
import { testimonials } from '../data/testimonials';
---

<section id="depoimentos" class="relative py-20 md:py-28 overflow-hidden">
  <!-- Background -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <!-- Header -->
    <div class="max-w-xl mb-14" data-reveal>
      <span class="text-primary text-sm font-medium uppercase tracking-wider">Depoimentos</span>
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl mt-3 leading-tight">
        Quem provou,<br /><span class="text-primary">recomenda</span>
      </h2>
    </div>

    <!-- Staggered testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class:list={[
          'relative rounded-2xl border border-white/5 bg-bg-card/60 backdrop-blur-sm p-6 md:p-8 transition-all duration-500 hover:border-primary/20',
          i === 1 ? 'md:translate-y-8' : '',
          i === 2 ? 'md:translate-y-4' : '',
        ]}>
          <!-- Quote mark -->
          <div class="text-primary/20 font-display text-6xl leading-none absolute top-4 right-6">"</div>

          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Text -->
          <p class="text-text-muted text-sm leading-relaxed mb-6 relative z-10">
            {t.text}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary/30 to-secondary/20 flex items-center justify-center">
              <span class="text-sm font-bold text-primary">{t.name.charAt(0)}</span>
            </div>
            <div>
              <p class="text-sm font-medium text-text">{t.name}</p>
              <p class="text-xs text-text-dim">comprou {t.product}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
