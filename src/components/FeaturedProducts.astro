---
import ProductCard from './ui/ProductCard.astro';
import { products } from '../data/products';

const featured = products[0]; // Chá de Camomila — popular
const others = products.slice(1, 5);
---

<section id="produtos" class="relative py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <!-- Section Header — offset left -->
    <div class="max-w-2xl mb-14" data-reveal>
      <span class="text-primary text-sm font-medium uppercase tracking-wider">Nossos produtos</span>
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl mt-3 leading-tight">
        Produtos que fazem<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">a diferença</span>
      </h2>
      <p class="text-text-muted mt-4 text-lg max-w-lg">
        Cada item é selecionado pensando na sua saúde e bem-estar. Sem atalhos, sem conservantes.
      </p>
    </div>

    <!-- Product Grid — asymmetric -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1fr_1fr_1fr] gap-5 auto-rows-auto">
      <!-- Featured large card spans 2 rows -->
      <div class="sm:row-span-2">
        <ProductCard product={featured} featured />
      </div>
      {others.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>

    <!-- View all -->
    <div class="mt-10 text-center">
      <a
        href="#categorias"
        class="inline-flex items-center gap-2 text-primary hover:text-primary-light font-medium transition-colors duration-300"
      >
        Ver todas as categorias
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
