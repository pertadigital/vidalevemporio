---
const scenarios = [
  {
    emoji: '🌅',
    title: 'Ritual matinal',
    description: 'Comece o dia com um chá quente e granola artesanal. Energia natural sem pressa.',
    gradient: 'from-amber-900/40 to-orange-900/20',
  },
  {
    emoji: '🍳',
    title: 'Na cozinha',
    description: 'Temperos naturais que transformam pratos simples em refeições extraordinárias.',
    gradient: 'from-emerald-900/40 to-teal-900/20',
  },
  {
    emoji: '💆',
    title: 'Bem-estar diário',
    description: 'Suplementos naturais que complementam sua rotina de forma simples e eficaz.',
    gradient: 'from-blue-900/40 to-indigo-900/20',
  },
];
---

<section class="relative py-20 md:py-28">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-bg-card/20 to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 md:px-8">
    <!-- Header — center -->
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="text-secondary text-sm font-medium uppercase tracking-wider">No seu dia a dia</span>
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl mt-3 leading-tight">
        Como se encaixa<br />na sua <span class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-primary">rotina</span>
      </h2>
    </div>

    <!-- Scenario cards — horizontal on mobile, editorial on desktop -->
    <div class="flex gap-5 overflow-x-auto pb-4 md:pb-0 md:overflow-visible md:grid md:grid-cols-3 snap-x snap-mandatory -mx-4 px-4 md:mx-0 md:px-0">
      {scenarios.map((scene, i) => (
        <div class:list={[
          'group shrink-0 w-[280px] md:w-auto snap-center rounded-2xl border border-white/5 overflow-hidden transition-all duration-500 hover:border-primary/20',
          i === 1 ? 'md:-translate-y-8' : '',
        ]}>
          <div class:list={['bg-gradient-to-br p-8 h-full flex flex-col', scene.gradient]}>
            <span class="text-5xl mb-6">{scene.emoji}</span>
            <h3 class="font-display font-bold text-xl text-text mb-2">{scene.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{scene.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
